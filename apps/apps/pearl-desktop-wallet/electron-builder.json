{
  "appId": "com.pearl.pearl.wallet",
  "productName": "Pearl Wallet",
  "directories": {
    "output": "dist"
  },
  "files": [
    "out/**/*",
    "resources/**/*",
    "package.json"
  ],
  "asar": true,
  "npmRebuild": false,
  "icon": "resources/icon.png",
  "mac": {
    "icon": "resources/icon.png",
    "category": "public.app-category.finance",
    "hardenedRuntime": true,
    "gatekeeperAssess": false,
    "entitlements": "build/entitlements.mac.plist",
    "entitlementsInherit": "build/entitlements.mac.plist",
    "notarize": false,
    "target": [
      {
        "target": "dmg",
        "arch": [
          "x64",
          "arm64"
        ]
      }
    ],
    "extraResources": [
      {
        "from": "bin/oyster-darwin-${arch}",
        "to": "bin/oyster-darwin-${arch}",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "win": {
    "icon": "resources/icon.png",
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    ],
    "extraResources": [
      {
        "from": "bin/oyster-windows-${arch}.exe",
        "to": "bin/oyster-windows-${arch}.exe",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "linux": {
    "icon": "resources/icon.png",
    "target": [
      {
        "target": "deb",
        "arch": [
          "x64"
        ]
      }
    ],
    "extraResources": [
      {
        "from": "bin/oyster-linux-${arch}",
        "to": "bin/oyster-linux-${arch}",
        "filter": [
          "**/*"
        ]
      }
    ],
    "category": "Office",
    "synopsis": "Pearl Desktop Wallet",
    "description": "The official open source desktop wallet for Pearl Network"
  },
  "deb": {
    "artifactName": "pearl-desktop-wallet_${version}_${arch}.${ext}",
    "packageName": "pearl-desktop-wallet",
    "depends": [
      "libgtk-3-0",
      "libnotify4",
      "libnss3",
      "libxss1",
      "libxtst6",
      "xdg-utils",
      "libatspi2.0-0",
      "libuuid1",
      "libsecret-1-0"
    ],
    "recommends": [
      "libappindicator3-1"
    ],
    "compression": "xz"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "buildUniversalInstaller": false,
    "artifactName": "Pearl-Wallet-Setup-${version}.${ext}"
  },
  "publish": null
}